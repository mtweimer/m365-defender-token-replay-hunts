// Primary telemetry: Defender for Office 365 Safe Links (`UrlClickEvents`) with Defender for Endpoint browser fallback (`DeviceNetworkEvents`).
// Behavior: Hunts reported lure-domain clicks or browser visits for a supplied impacted-user list.
// Missing telemetry: Returns empty results instead of a semantic error.
let users = dynamic(["<user1@domain.com>", "<user2@domain.com>"]);
let lureDomains = dynamic([
    "workers.dev", "vercel.app", "amplifyapp.com", "customervoice.microsoft.com",
    "secure-web.cisco.com", "mimecastprotect.com", "trendmicro.com"
]);
union isfuzzy=true
(
    UrlClickEvents
    | where AccountUpn in (users)
    | where Url has_any (lureDomains)
    | project Timestamp, AccountUpn, ActionType, Url, UrlChain, Workload, NetworkMessageId,
              EvidenceSource = "UrlClickEvents"
),
(
    DeviceNetworkEvents
    | extend AccountUpn = coalesce(InitiatingProcessAccountUpn, strcat(InitiatingProcessAccountDomain, "\\", InitiatingProcessAccountName))
    | where AccountUpn in (users)
    | where isnotempty(RemoteUrl)
    | where RemoteUrl has_any (lureDomains)
    | where InitiatingProcessFileName in~ ("chrome.exe", "msedge.exe", "firefox.exe", "iexplore.exe", "safari.exe", "brave.exe", "opera.exe")
    | project Timestamp, AccountUpn, ActionType, Url = RemoteUrl, UrlChain = "", Workload = "EndpointBrowser", NetworkMessageId = "",
              EvidenceSource = "DeviceNetworkEvents"
),
(
    datatable(
        Timestamp:datetime,
        AccountUpn:string,
        ActionType:string,
        Url:string,
        UrlChain:string,
        Workload:string,
        NetworkMessageId:string,
        EvidenceSource:string
    )[]
)
| order by Timestamp desc
