// Primary telemetry: Defender for Office 365 mail telemetry (`EmailEvents`, `EmailUrlInfo`).
// Behavior: Correlates delivered messages with suspicious URLs seen in the campaign infrastructure set.
// Missing telemetry: Returns empty results instead of a semantic error.
let lureDomains = dynamic([
    "workers.dev", "vercel.app", "amplifyapp.com", "customervoice.microsoft.com",
    "secure-web.cisco.com", "mimecastprotect.com", "trendmicro.com"
]);
let suspiciousMail = union isfuzzy=true
(
    EmailUrlInfo
    | where Timestamp >= ago(30d)
    | where Url has_any (lureDomains)
    | project NetworkMessageId, Url, UrlDomain, RecipientEmailAddress
),
(
    datatable(
        NetworkMessageId:string,
        Url:string,
        UrlDomain:string,
        RecipientEmailAddress:string
    )[]
);
union isfuzzy=true
(
    EmailEvents
    | where Timestamp >= ago(30d)
    | join kind=inner suspiciousMail on NetworkMessageId
    | project Timestamp, RecipientEmailAddress, SenderFromAddress, Subject, Url, UrlDomain,
              DeliveryAction, LatestDeliveryAction, ThreatTypes, DetectionMethods
),
(
    datatable(
        Timestamp:datetime,
        RecipientEmailAddress:string,
        SenderFromAddress:string,
        Subject:string,
        Url:string,
        UrlDomain:string,
        DeliveryAction:string,
        LatestDeliveryAction:string,
        ThreatTypes:string,
        DetectionMethods:string
    )[]
)
| order by Timestamp desc
