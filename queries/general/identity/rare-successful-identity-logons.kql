// Primary telemetry: Identity-related Advanced Hunting telemetry (`IdentityLogonEvents`).
// Behavior: Finds successful logons from IPs not seen for the same account in the prior baseline period.
// Missing telemetry: Returns empty results instead of a semantic error.
let logonEvents = union isfuzzy=true
(
    IdentityLogonEvents
    | project Timestamp, ActionType, AccountUpn, IPAddress, Location, ISP
),
(
    datatable(
        Timestamp:datetime,
        ActionType:string,
        AccountUpn:string,
        IPAddress:string,
        Location:string,
        ISP:string
    )[]
);
let baseline = logonEvents
| where Timestamp between (ago(37d) .. ago(7d))
| where ActionType == "LogonSuccess"
| summarize by AccountUpn, IPAddress;
logonEvents
| where Timestamp > ago(7d)
| where ActionType == "LogonSuccess"
| join kind=leftanti baseline on AccountUpn, IPAddress
| summarize FirstSeen=min(Timestamp), LastSeen=max(Timestamp), LogonCount=count() by AccountUpn, IPAddress, Location, ISP
| order by LastSeen desc
